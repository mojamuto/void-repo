# Template file for 'gram'
pkgname=gram
version=2.1.2
revision=1
build_style=cargo
build_helper=rust
hostmakedepends="pkg-config"
make_build_args=" --package gram --package cli"
makedepends="gettext-devel cmake jq elfutils-devel
 fontconfig-devel libxcb-devel libxkbcommon-devel libzstd-devel
 openssl-devel wayland-devel sqlite-devel libgit2-1.9-devel"
depends="vulkan-loader"
short_desc="The Gram Code Editor"
maintainer="kim"
license="GPL-3.0-or-later, AGPL-3.0-or-later, Apache-2.0"
homepage="https://codeberg.org/GramEditor/gram"
changelog="https://codeberg.org/GramEditor/gram/releases"
distfiles="https://codeberg.org/GramEditor/gram/archive/${version}.tar.gz"
checksum=58883c8dce2099445de6db819fa2ce678c0a5e2b572b3fb3d16dd1602eb44087

export RELEASE_VERSION="$version"

post_build() {
	# Get licenses from deps
	script/generate-licenses
}

do_install() {
	vmkdir usr/bin
	vmkdir usr/libexec
	vmkdir usr/share/applications
	vmkdir usr/share/icons/hicolor/scalable/apps
	vmkdir usr/share/icons/hicolor/symbolic/apps
	vcopy target/*/release/gram usr/libexec/gram-editor
	vcopy target/*/release/cli usr/bin/gram
	vcopy crates/gram/resources/app.liten.Gram-symbolic.svg usr/share/icons/hicolor/symbolic/apps
	vcopy crates/gram/resources/app.liten.Gram.svg usr/share/icons/hicolor/scalable/apps

	# Copy combined and included
	# license files into package
	vlicense assets/licenses.md
	vlicense LICENSE-APACHE
	vlicense LICENSE-GPL

	# Create .desktop file from bundled template
	sed crates/gram/resources/gram.desktop.in \
		-e 's|\$APP_NAME|Gram|g' \
		-e 's|\$APP_CLI|gram|g' \
		-e 's|\$APP_ARGS|%U|g' \
		-e 's|\$APP_ICON|app.liten.Gram|g' \
		-e 's|\$DO_STARTUP_NOTIFY|true|g' \
	> ${DESTDIR}/usr/share/applications/gram.desktop
}