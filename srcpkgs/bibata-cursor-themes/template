# Template file for 'bibata-cursor-themes'
pkgname=bibata-cursor-themes
version=2.0.7
revision=1
metapackage=yes
depends="${pkgname}-modern-amber>=${version}_${revision}
 ${pkgname}-modern-classic>=${version}_${revision}
 ${pkgname}-modern-ice>=${version}_${revision}"
short_desc="Open source, compact, and material designed cursor set"
maintainer="Alex March <alex@hosaka.cc>"
license="GPL-3.0-or-later"
homepage="https://github.com/ful1e5/Bibata_Cursor"
distfiles="https://github.com/ful1e5/Bibata_Cursor/releases/download/v${version}/Bibata-Modern-Amber.tar.xz
 https://github.com/ful1e5/Bibata_Cursor/releases/download/v${version}/Bibata-Modern-Classic.tar.xz
 https://github.com/ful1e5/Bibata_Cursor/releases/download/v${version}/Bibata-Modern-Ice.tar.xz"
checksum="58b7ac00ed3cb45acb6b917cb9807a553873f1cca5c91348c4abaebe638e5884
 7d3495864e5bbef02f5e77de760b2905903b63c71495a78ef6306d19a3b556d8
 a68cae60c4dc706350e194ebc91c5fe48bc7bc9d59e119555834a2a7ee5078ef"

_themes=(
	'Modern-Amber'
	'Modern-Classic'
	'Modern-Ice'
)

do_install() {
	vmkdir usr/share/icons
	for theme in "${_themes[@]}"; do
		vcopy "Bibata-${theme}" usr/share/icons
	done
}

bibata-cursor-themes-modern-amber_package() {
	short_desc+=" - yellowish and sharp edge"
	pkg_install() {
		vmove usr/share/icons/Bibata-Modern-Amber
	}
}

bibata-cursor-themes-modern-classic_package() {
	short_desc+=" - black and rounded edge"
	pkg_install() {
		vmove usr/share/icons/Bibata-Modern-Classic
	}
}

bibata-cursor-themes-modern-ice_package() {
	short_desc+=" - white and rounded edge"
	pkg_install() {
		vmove usr/share/icons/Bibata-Modern-Ice
	}
}
